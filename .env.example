# Pajakia Environment Variables

# App
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pajakia
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=pajakia-webhook-verify
WHATSAPP_APP_SECRET=your-app-secret

# OpenAI (for OCR + Q&A)
OPENAI_API_KEY=sk-your-openai-key

# S3 Document Storage (optional — falls back to local)
S3_BUCKET=pajakia-documents
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
